# Discord Bot Token
# 從 Discord Developer Portal 獲取
BOT_TOKEN=your_discord_bot_token_here

# MongoDB Password
# 用於連接 MongoDB Atlas 資料庫
MONGO_PASSWORD=your_mongodb_password_here

# Steam 特價推播 (台灣區)
# 推播目標 Discord 頻道 ID;若留空則讀取 config.json 內的 steamDeals.channelId
DISCORD_DEALS_CHANNEL_ID=
# Cron 排程,預設每兩小時 (覆寫 config.json 內的設定)
STEAM_DEALS_CRON=0 */2 * * *
# 設為 false 可暫停推播 (預設 true)
STEAM_DEALS_ENABLED=true
# 設為 true 時只 log 不真的發送,方便驗證
STEAM_DEALS_DRY_RUN=false
