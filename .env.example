# Discord Bot Token
# 從 Discord Developer Portal 獲取
BOT_TOKEN=your_discord_bot_token_here

# MongoDB Password
# 用於連接 MongoDB Atlas 資料庫
MONGO_PASSWORD=your_mongodb_password_here

# Steam 特價推播 (台灣區)
# 推播目標 Discord 頻道 ID;若留空則讀取 config.json 內的 steamDeals.channelId
DISCORD_DEALS_CHANNEL_ID=
# 小黑盒 RSS feed URL (覆寫 config.json 內的 feedUrl)
XIAOHEIHE_FEED_URL=https://discord-news.zeabur.app/xiaoheihe/discount/pc
# Cron 排程,預設每兩小時 (覆寫 config.json 內的設定)
STEAM_DEALS_CRON=0 */2 * * *
# 設為 false 可暫停推播 (預設 true)
STEAM_DEALS_ENABLED=true
# 設為 true 時只 log 不真的發送,方便驗證
STEAM_DEALS_DRY_RUN=false
# 設為 true 時 bot 啟動就立刻跑一次 (僅供首次部署驗證,平時請保持 false)
STEAM_DEALS_RUN_ON_START=false

# 喜加一 (限時免費) 推播
# 預設沿用上面的 DISCORD_DEALS_CHANNEL_ID,若想推到別的頻道才設這個
DISCORD_FREE_GAMES_CHANNEL_ID=
# Cron 排程,預設每 6 小時的 30 分跑一次 (錯開特價推播)
FREE_GAMES_CRON=30 */6 * * *
# 設為 false 可暫停 (預設 true)
FREE_GAMES_ENABLED=true
# Dry-run 與啟動立刻跑 (同步驗證用)
FREE_GAMES_DRY_RUN=false
FREE_GAMES_RUN_ON_START=false
# GamerPower API base URL (留空則用 https://www.gamerpower.com/api/giveaways)
FREE_GAMES_API_URL=

# RSS 推播 (picnob/threads,設定見 src/config/rssFeeds.js)
# Cron 排程,預設每兩小時
RSS_CRON=0 */2 * * *
RSS_TIMEZONE=Asia/Taipei
# 啟動立刻跑一次 (驗證用,平時 false)
RSS_RUN_ON_START=false
# 抓 feed 的 timeout (毫秒);discord-news.zeabur.app 是即時抓取,冷啟動會慢,預設 45000
RSS_FETCH_TIMEOUT_MS=45000
# 抓 feed 失敗時的最大嘗試次數 (含第一次),預設 3
RSS_FETCH_MAX_ATTEMPTS=3
# 貼文 pubDate 早於此小時數一律不推播 (避免 gateway 重生 guid 時倒灌舊文),預設 72,設 0 關閉
RSS_MAX_ITEM_AGE_HOURS=72

# Twitch 開台通知
# 從 https://dev.twitch.tv/console/apps 註冊 App，拿 Client ID + Client Secret
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
# 推播到的 Discord 頻道 ID；留空會讀 config/twitch.json 內的 channelId
DISCORD_TWITCH_CHANNEL_ID=
# 要追蹤的 Twitch 帳號 (login，逗號分隔)；留空則用 config/twitch.json
TWITCH_STREAMERS=
# Cron 排程,預設每分鐘檢查一次
TWITCH_LIVE_CRON=*/1 * * * *
# 設為 false 可暫停 (預設 true)
TWITCH_LIVE_ENABLED=true
# Dry-run 與啟動立刻跑 (僅供驗證用)
TWITCH_LIVE_DRY_RUN=false
TWITCH_LIVE_RUN_ON_START=false
