# Discord Bot Token
# 從 Discord Developer Portal 獲取
BOT_TOKEN=your_discord_bot_token_here

# MongoDB Password
# 用於連接 MongoDB Atlas 資料庫
MONGO_PASSWORD=your_mongodb_password_here

# Steam 特價推播 (台灣區)
# 推播目標 Discord 頻道 ID;若留空則讀取 config.json 內的 steamDeals.channelId
DISCORD_DEALS_CHANNEL_ID=
# 小黑盒 RSS feed URL (覆寫 config.json 內的 feedUrl)
XIAOHEIHE_FEED_URL=https://discord-news.zeabur.app/xiaoheihe/discount/pc
# Cron 排程,預設每兩小時 (覆寫 config.json 內的設定)
STEAM_DEALS_CRON=0 */2 * * *
# 設為 false 可暫停推播 (預設 true)
STEAM_DEALS_ENABLED=true
# 設為 true 時只 log 不真的發送,方便驗證
STEAM_DEALS_DRY_RUN=false
# 設為 true 時 bot 啟動就立刻跑一次 (僅供首次部署驗證,平時請保持 false)
STEAM_DEALS_RUN_ON_START=false

# 喜加一 (限時免費) 推播
# 預設沿用上面的 DISCORD_DEALS_CHANNEL_ID,若想推到別的頻道才設這個
DISCORD_FREE_GAMES_CHANNEL_ID=
# Cron 排程,預設每 6 小時的 30 分跑一次 (錯開特價推播)
FREE_GAMES_CRON=30 */6 * * *
# 設為 false 可暫停 (預設 true)
FREE_GAMES_ENABLED=true
# Dry-run 與啟動立刻跑 (同步驗證用)
FREE_GAMES_DRY_RUN=false
FREE_GAMES_RUN_ON_START=false
# 各平台 RSS feed URL (留空則用 config.json 預設)
FREE_GAMES_EPIC_FEED_URL=
FREE_GAMES_STEAM_FEED_URL=
FREE_GAMES_GOG_FEED_URL=
